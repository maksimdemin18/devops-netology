# Local .terraform directories
.terraform/

# .tfstate files
*.tfstate
*.tfstate.*

# Crash log files
crash.log
crash.*.log

# Exclude all .tfvars files (sensitive data, environment-specific)
*.tfvars
*.tfvars.json

# Ignore override files
override.tf
override.tf.json
*_override.tf
*_override.tf.json

# Ignore transient lock info file
.terraform.tfstate.lock.info

# Ignore CLI configuration files
.terraformrc
terraform.rc

# Optional: ignore plan output files (if you use terraform plan -out=plan)
*.tfplan

# Optional: ignore graph output files
*.dot

# Optional: ignore planout files (custom name)
planout

# --- Дополнительно для удобства ---
# Файлы IDE (VSCode, IntelliJ, и т.д.)
.vscode/
.idea/
*.swp
*.swo

# Файлы ОС
.DS_Store
Thumbs.db

# Логи и временные файлы
*.log
*.tmp
